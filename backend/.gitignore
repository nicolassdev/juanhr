# ── Dependencies ──────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Build output ──────────────────────────────
dist/
build/

# ── Environment variables (NEVER commit these) ─
.env
.env.local
.env.development
.env.production
.env.staging
.env.test

# ── Prisma ────────────────────────────────────
# Keep schema.prisma and migrations — DO commit those
# But ignore the generated client (regenerated on npm install)
node_modules/.prisma/

# ── Uploads (user files — not for git) ────────
uploads/
!uploads/.gitkeep

# ── Logs ──────────────────────────────────────
logs/
*.log

# ── OS files ──────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Editor ────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── TypeScript cache ──────────────────────────
*.tsbuildinfo
tsconfig.tsbuildinfo